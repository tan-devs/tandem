{
	"name": "tandem",
	"private": true,
	"version": "0.0.1",
	"type": "module",
	"repository": {
		"type": "git",
		"url": "git+https://github.com/tan-devs/tandem.git"
	},
	"scripts": {
		"clense": "pnpm format && pnpm lint && pnpm check",
		"dev:client": "vite dev --host",
		"dev:frontend": "vite dev --host 127.0.0.1 --port 5173",
		"dev:server": "pnpm dlx convex dev",
		"dev": "concurrently --kill-others --prefix-colors red,yellow --names \"svelte,convex\" \"pnpm dev:client\" \"pnpm dev:server\"",
		"build": "vite build",
		"preview": "vite preview",
		"prepare": "svelte-kit sync || echo ''",
		"check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
		"check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
		"lint": "prettier --check . && eslint .",
		"format": "prettier --write .",
		"test:unit": "vitest",
		"test": "npm run test:unit -- --run && npm run test:e2e",
		"test:e2e": "playwright test",
		"storybook": "storybook dev -p 6006",
		"build-storybook": "storybook build"
	},
	"devDependencies": {
		"@eslint/compat": "^2.0.3",
		"@eslint/js": "^10.0.1",
		"@playwright/test": "^1.58.2",
		"@storybook/addon-svelte-csf": "^5.1.2",
		"@storybook/sveltekit": "^10.3.5",
		"@sveltejs/adapter-vercel": "^6.3.1",
		"@sveltejs/kit": "^2.50.2",
		"@sveltejs/vite-plugin-svelte": "^6.2.4",
		"@types/node": "^22",
		"@vitest/browser-playwright": "^4.1.0",
		"eslint": "^10.0.3",
		"eslint-config-prettier": "^10.1.8",
		"eslint-plugin-storybook": "^10.3.5",
		"eslint-plugin-svelte": "^3.15.2",
		"globals": "^17.4.0",
		"mdsvex": "^0.12.6",
		"playwright": "^1.58.2",
		"prettier": "^3.8.1",
		"prettier-plugin-svelte": "^3.4.1",
		"storybook": "^10.3.5",
		"svelte": "^5.54.0",
		"svelte-check": "^4.4.2",
		"typescript": "^5.9.3",
		"typescript-eslint": "^8.57.0",
		"vite": "^7.3.1",
		"vite-plugin-devtools-json": "^1.0.0",
		"vitest": "^4.1.0",
		"vitest-browser-svelte": "^2.0.2"
	},
	"dependencies": {
		"@convex-dev/better-auth": "^0.11.4",
		"@liveblocks/client": "^3.17.0",
		"@liveblocks/node": "^3.17.0",
		"@liveblocks/yjs": "^3.17.0",
		"@lucide/svelte": "^1.8.0",
		"@mmailaender/convex-svelte": "^0.18.0",
		"@webcontainer/api": "^1.6.1",
		"@xterm/addon-fit": "^0.11.0",
		"@xterm/xterm": "^6.0.0",
		"better-auth": "^1.5.6",
		"bits-ui": "^2.17.2",
		"concurrently": "^9.2.1",
		"convex": "^1.34.1",
		"convex-svelte": "^0.0.12",
		"is-network-error": "^1.3.1",
		"monaco-editor": "^0.55.1",
		"paneforge": "^1.0.2",
		"y-monaco": "^0.1.6",
		"y-protocols": "^1.0.7",
		"yjs": "^13.6.30"
	},
	"pnpm": {
		"overrides": {
			"y-protocols": "^1.0.7",
			"yjs": "^13.6.30",
			"better-auth": "~1.5.0"
		}
	}
}
